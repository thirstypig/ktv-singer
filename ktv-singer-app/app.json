{
  "expo": {
    "name": "KTV Singer",
    "slug": "ktv-singer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ktvsinger.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow KTV Singer to scan QR codes for TV pairing",
        "NSMicrophoneUsageDescription": "KTV Singer needs microphone access for karaoke singing"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow KTV Singer to scan QR codes for TV pairing"
        }
      ],
      "expo-audio"
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    }
  }
}
