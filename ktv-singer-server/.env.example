# Database — Supabase PostgreSQL (required)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Authentication - OIDC Provider (optional in dev)
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
APP_URL=http://localhost:4040
SESSION_SECRET=your-session-secret

# YouTube Data API (required)
YOUTUBE_API_KEY=your-youtube-api-key

# Vocal Separation Services (optional)
LALAL_AI_API_KEY=your-lalal-ai-key
GAUDIO_API_KEY=your-gaudio-api-key

# Redis (optional — in-memory fallback if not set)
# REDIS_URL=redis://localhost:6385

# Server port (default: 4040) — see PORTS.md for full port registry
PORT=4040
NODE_ENV=development
